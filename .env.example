# Site Configuration
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Telegram Integration (required for form submissions)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email Integration (fallback for form submissions)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=noreply@yourdomain.com
LEADS_EMAIL_TO=your-email@yourdomain.com

# Analytics (optional)
# Add your analytics IDs here if using Google Analytics or other services
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
