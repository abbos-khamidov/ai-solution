# ─── Vercel / Production ─────────────────────────────────────
# Set these in Vercel: Project → Settings → Environment Variables

# Canonical site URL (required for OG, sitemap, metadata). Use your Vercel URL or custom domain.
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Optional: lead form / contact integrations (when you add Telegram or Resend)
# LEADS_EMAIL_TO=you@example.com
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=noreply@yourdomain.com
# TELEGRAM_BOT_TOKEN=123:xxx
# TELEGRAM_CHAT_ID=-100xxxx
